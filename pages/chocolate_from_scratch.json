                "fg": "#E8C9A0",
                "bg": "#2A1A0A"
              },
              {
                "type": "text",
                "content": "  Cool      28 C   steady hand  |   Working  31 C   pour & mold",
                "fg": "#E8C9A0",
                "bg": "#2A1A0A"
              }
            ]
          },
